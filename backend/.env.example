# Server
PORT=3001
NODE_ENV=development
API_BASE_URL=http://localhost:3001

# Database (SQLite for dev, switch to PostgreSQL for production)
DATABASE_PATH=./data/leads.db

# JWT Secret for admin dashboard
JWT_SECRET=change-this-to-a-random-64-char-string

# Admin credentials (change these!)
ADMIN_EMAIL=admin@insureai.com
ADMIN_PASSWORD=change-this-password

# CORS — your chatbot's domain
FRONTEND_URL=http://localhost:3000

# Lead Distribution Settings
DISTRIBUTION_MODE=hybrid
EXCLUSIVE_MIN_BID=15.00
MAX_SHARED_BUYERS=3
PING_TIMEOUT_MS=3000
POST_TIMEOUT_MS=5000

# Duplicate Window (hours) — reject leads with same phone/email within this window
DUPLICATE_WINDOW_HOURS=72

# Logging
LOG_LEVEL=info
